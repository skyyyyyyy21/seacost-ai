[project]
requires = ["python-3.12"]
project_type = "web"

[preview]
preview_enable = "enabled"

[dev]
build = ["bash", "EchoMind/scripts/coze-preview-build.sh"]
run = ["bash", "EchoMind/scripts/coze-preview-run.sh"]

[deploy]
build = ["bash", "EchoMind/scripts/setup.sh"]
run = ["bash", "EchoMind/scripts/http_run.sh", "-p", "5000"]

[deploy.profile]
kind = "service"
flavor = "web"

[subprojects]
path = ["EchoMind"]
