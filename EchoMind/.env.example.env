# EchoMind 智能客服系统 - 环境变量配置示例
# 复制此文件为 .env 并填写实际的配置值

# ============================================
# 应用基础配置
# ============================================
APP_NAME=EchoMind
APP_ENV=production
LOG_LEVEL=INFO
DEBUG=false

# ============================================
# API 服务配置
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4
MAX_CONNECTIONS=1000
REQUEST_TIMEOUT=30

# ============================================
# Anthropic Claude API 配置
# ============================================
ANTHROPIC_API_KEY=sk-2a4ec3dee4dd4c8e81fb965809e9e1f3
CLAUDE_MODEL=deepseek-v4-flash
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.7

# ============================================
# Redis 缓存配置
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=echomind123
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL=30

# ============================================
# ChromaDB 向量数据库配置
# ============================================
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_AUTH_TOKEN=echomind-token-123
CHROMA_COLLECTION_NAME=echomind_memories

# ============================================
# 意图识别配置
# ============================================
INTENT_MODEL=sentence-transformers/all-MiniLM-L6-v2
INTENT_CONFIDENCE_THRESHOLD=0.6
INTENT_CACHE_SIZE=1000
INTENT_CACHE_TTL=3600

# ============================================
# Agent 编排配置
# ============================================
AGENT_TIMEOUT=30
AGENT_MAX_PARALLEL=3
AGENT_RATE_LIMIT=100
AGENT_PRIORITY_ENABLED=true

# ============================================
# 工具调用配置
# ============================================
TOOL_TIMEOUT=30
TOOL_RATE_LIMIT=100
TOOL_CACHE_ENABLED=true
TOOL_CACHE_TTL=300
TOOL_CIRCUIT_BREAKER_THRESHOLD=5
TOOL_CIRCUIT_BREAKER_TIMEOUT=60

# ============================================
# 记忆管理配置
# ============================================
MEMORY_MAX_WORKING=50
MEMORY_MAX_TOKENS=8000
MEMORY_COMPRESSION_THRESHOLD=10
MEMORY_COMPRESSION_RATIO=0.3
MEMORY_TTL_HOURS=720

# ============================================
# 监控配置
# ============================================
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
ALERT_WEBHOOK_URL=
MONITORING_INTERVAL=5
ANOMALY_DETECTION_THRESHOLD=2.0

# ============================================
# 评测配置
# ============================================
EVALUATION_ENABLED=true
EVALUATION_INTERVAL=3600
QUALITY_ASSESSMENT_ENABLED=true
REGRESSION_TEST_ENABLED=true

# ============================================
# 安全配置
# ============================================
SECRET_KEY=your_secret_key_here_change_this_in_production
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# CORS 配置
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# ============================================
# 日志配置
# ============================================
LOG_FILE=./logs/echomind.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================
# 数据库配置 (可选)
# ============================================
# DATABASE_URL=postgresql://user:password@localhost:5432/echomind
# DATABASE_POOL_SIZE=20
# DATABASE_MAX_OVERFLOW=10
# DATABASE_POOL_TIMEOUT=30

# ============================================
# 外部服务配置 (可选)
# ============================================
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# PAGERDUTY_API_KEY=your_pagerduty_api_key
# SENTRY_DSN=your_sentry_dsn

# ============================================
# 功能开关
# ============================================
ENABLE_TELEMETRY=false
ENABLE_ANALYTICS=false
ENABLE_DEBUG_ENDPOINTS=false
ENABLE_SWAGGER_UI=true